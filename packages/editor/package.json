{
  "name": "@namelesserlx/editor",
  "version": "0.1.0",
  "private": false,
  "description": "React Rich Text Editor for Tiptap with a batteries-included, JSON-first editor SDK, built-in UI, readonly rendering, and HTML/Markdown import-export.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./core/extensions": {
      "types": "./dist/core/extensions.d.ts",
      "import": "./dist/core/extensions.js",
      "default": "./dist/core/extensions.js"
    },
    "./core/model": {
      "types": "./dist/core/model.d.ts",
      "import": "./dist/core/model.js",
      "default": "./dist/core/model.js"
    },
    "./format": {
      "types": "./dist/format/index.d.ts",
      "import": "./dist/format/index.js",
      "default": "./dist/format/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js",
      "default": "./dist/i18n/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "default": "./dist/react/index.js"
    },
    "./react/controller": {
      "types": "./dist/react/controller.d.ts",
      "import": "./dist/react/controller.js",
      "default": "./dist/react/controller.js"
    },
    "./react/editor": {
      "types": "./dist/react/editor.d.ts",
      "import": "./dist/react/editor.js",
      "default": "./dist/react/editor.js"
    },
    "./readonly": {
      "types": "./dist/readonly/index.d.ts",
      "import": "./dist/readonly/index.js",
      "default": "./dist/readonly/index.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "import": "./dist/security/index.js",
      "default": "./dist/security/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "pnpm run build:js && pnpm run build:types",
    "build:js": "vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:performance": "vitest run tests/performance",
    "size": "pnpm run build && node scripts/measure-bundle.mjs",
    "test:watch": "vitest",
    "prepack": "pnpm run build",
    "dev": "concurrently -n js,types -c blue,magenta \"vite build --watch\" \"tsc -p tsconfig.build.json --watch --preserveWatchOutput\""
  },
  "keywords": [
    "tiptap",
    "tiptap-react",
    "react",
    "react-rich-text-editor",
    "rich-text-editor",
    "wysiwyg",
    "json-first",
    "editor-sdk",
    "markdown-editor",
    "html-editor",
    "readonly-renderer",
    "content-editor"
  ],
  "author": {
    "name": "namelesserlx",
    "email": "mwu9558@gmail.com",
    "url": "https://github.com/namelesserlx"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/namelesserlx/namelessler-editor.git",
    "directory": "packages/editor"
  },
  "homepage": "https://github.com/namelesserlx/namelessler-editor/tree/main/packages/editor#readme",
  "bugs": {
    "url": "https://github.com/namelesserlx/namelessler-editor/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.0.9",
  "peerDependencies": {
    "@tiptap/core": ">=3.22.5 <4",
    "@tiptap/extension-code-block-lowlight": ">=3.22.5 <4",
    "@tiptap/extension-highlight": ">=3.22.5 <4",
    "@tiptap/extension-link": ">=3.22.5 <4",
    "@tiptap/extension-placeholder": ">=3.22.5 <4",
    "@tiptap/extension-table": ">=3.22.5 <4",
    "@tiptap/extension-task-item": ">=3.22.5 <4",
    "@tiptap/extension-task-list": ">=3.22.5 <4",
    "@tiptap/extension-text-align": ">=3.22.5 <4",
    "@tiptap/extension-text-style": ">=3.22.5 <4",
    "@tiptap/extension-underline": ">=3.22.5 <4",
    "@tiptap/html": ">=3.22.5 <4",
    "@tiptap/markdown": ">=3.22.5 <4",
    "@tiptap/pm": ">=3.22.5 <4",
    "@tiptap/react": ">=3.22.5 <4",
    "@tiptap/starter-kit": ">=3.22.5 <4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "dompurify": "^3.4.1",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.553.0",
    "marked": "^17.0.6"
  },
  "devDependencies": {
    "@tiptap/core": "3.22.5",
    "@tiptap/extension-code-block-lowlight": "3.22.5",
    "@tiptap/extension-highlight": "3.22.5",
    "@tiptap/extension-link": "3.22.5",
    "@tiptap/extension-placeholder": "3.22.5",
    "@tiptap/extension-table": "3.22.5",
    "@tiptap/extension-task-item": "3.22.5",
    "@tiptap/extension-task-list": "3.22.5",
    "@tiptap/extension-text-align": "3.22.5",
    "@tiptap/extension-text-style": "3.22.5",
    "@tiptap/extension-underline": "3.22.5",
    "@tiptap/html": "3.22.5",
    "@tiptap/markdown": "3.22.5",
    "@tiptap/pm": "3.22.5",
    "@tiptap/react": "3.22.5",
    "@tiptap/starter-kit": "3.22.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
