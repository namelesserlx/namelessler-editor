{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    /* Path alias */
    "paths": {
      "@namelesserlx/editor": ["../../packages/editor/src/index.ts"],
      "@namelesserlx/editor/format": ["../../packages/editor/src/format/index.ts"],
      "@namelesserlx/editor/react/controller": ["../../packages/editor/src/react/controller.ts"],
      "@namelesserlx/editor/react/editor": ["../../packages/editor/src/react/editor.ts"],
      "@namelesserlx/editor/ui": ["../../packages/editor/src/ui/index.ts"],
      "@/*": ["./src/*"]
    },
    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
